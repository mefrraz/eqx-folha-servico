# Supabase — obtém estas keys em https://supabase.com/dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — para admin updateUser (email/password)
# NUNCA expor no cliente! Só server-side. Em Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin delete password — palavra-passe para confirmar eliminação de users
# Guarda esta password só para os admins da plataforma
ADMIN_DELETE_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Gmail — para enviar emails de notificação
# Criar "App Password" em https://myaccount.google.com/apppasswords
GMAIL_USER=colaboradoreshoraseqx@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Email do admin que recebe notificações
ADMIN_EMAIL=colaboradoreshoraseqx@gmail.com
